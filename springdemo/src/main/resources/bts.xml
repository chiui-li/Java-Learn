<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.UserMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.entity.User">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="password" property="password" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="age" property="age" jdbcType="INTEGER"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 基础字段列表 -->
    <sql id="Base_Column_List">
        id, username, password, email, age, status, create_time, update_time
    </sql>

    <!-- 查询：根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap" parameterType="java.lang.Long">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        WHERE id = #{id}
    </select>

    <!-- 查询：根据条件查询（动态SQL） -->
    <select id="selectByCondition" resultMap="BaseResultMap" parameterType="com.example.entity.User">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="email != null and email != ''">
                AND email = #{email}
            </if>
            <if test="age != null">
                AND age = #{age}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <!-- 查询：分页查询 -->
    <select id="selectByPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        ORDER BY id DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 查询：统计总数 -->
    <select id="countTotal" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM user
    </select>

    <!-- 插入：普通插入 -->
    <insert id="insert" parameterType="com.example.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, password, email, age, status, create_time, update_time)
        VALUES (#{username}, #{password}, #{email}, #{age}, #{status}, NOW(), NOW())
    </insert>

    <!-- 插入：批量插入 -->
    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO user (username, password, email, age, status, create_time, update_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.username}, #{item.password}, #{item.email}, #{item.age}, #{item.status}, NOW(), NOW())
        </foreach>
    </insert>

    <!-- 更新：根据ID更新（动态字段） -->
    <update id="updateById" parameterType="com.example.entity.User">
        UPDATE user
        <set>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="email != null and email != ''">
                email = #{email},
            </if>
            <if test="age != null">
                age = #{age},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 更新：根据条件批量更新 -->
    <update id="updateByCondition">
        UPDATE user
        SET status = #{status}, update_time = NOW()
        <where>
            <if test="ids != null and ids.size() > 0">
                id IN
                <foreach collection="ids" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>
        </where>
    </update>

    <!-- 删除：根据ID删除 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM user
        WHERE id = #{id}
    </delete>

    <!-- 删除：批量删除 -->
    <delete id="deleteBatch" parameterType="java.util.List">
        DELETE FROM user
        WHERE id IN
        <foreach collection="list" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <!-- 删除：根据条件删除 -->
    <delete id="deleteByCondition" parameterType="com.example.entity.User">
        DELETE FROM user
        <where>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="age != null and age &lt; 18">
                AND age = #{age}
            </if>
        </where>
    </delete>

    <!-- 动态SQL：choose/when/otherwise -->
    <select id="selectByChoose" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user
        <where>
            <choose>
                <when test="username != null and username != ''">
                    AND username = #{username}
                </when>
                <when test="email != null and email != ''">
                    AND email = #{email}
                </when>
                <otherwise>
                    AND status = 1
                </otherwise>
            </choose>
        </where>
    </select>

</mapper>