<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springdemo.mapper.UserMapper">
    <sql id="user_columns">
        id, username, email, created_at, updated_at, password_updated_at
    </sql>
    <select id="selectUserList" resultType="User">
        select <include refid="user_columns" /> from users
    </select>

    <insert id="addUser" parameterType="User" >
        INSERT INTO users(username, password, email) VALUES(
            #{username},
            #{password},
            #{email}
        )
    </insert>

    <delete id="delUser" parameterType="long">
        delete from users where id = #{id}
    </delete>

    <select id="findUserByPassword">
        select <include refid="user_columns" /> from users where username=#{username} and password=#{password}
    </select>

    <!-- findUserById -->
    <select id="findUserById">
        select <include refid="user_columns" /> from users where id=#{id}
    </select>


    <select id="findUserByEmail">
        select <include refid="user_columns" /> from users where email=#{email} or username=#{username}
    </select>


</mapper>
